# Copy this file to .env.local and fill in real values.
# NEVER put real API keys in .env.example — that file is often committed to Git.

# OpenSea API v2 — get a key: OpenSea → Settings → Developer
OPENSEA_API_KEY=

# Chain slug for CapyCamp (Abstract mainnet). OpenSea: chain/abstract
OPENSEA_CHAIN=abstract

# Local NFT art: public/{folder}/{tokenId}.png (default folder URL path is /images)
# Example: public/images/1.png → /images/1.png
# To use public/nfts/ instead: NEXT_PUBLIC_NFT_LOCAL_IMAGE_BASE=/nfts
# NEXT_PUBLIC_NFT_LOCAL_IMAGE_BASE=

# Optional fallback (Ethereum mainnet only — not used for Abstract)
# ALCHEMY_API_KEY=
